# Device tokens: format is token:device_id:device_name:platform
DEVICE_TOKEN_1=changeme_token1:my-pc:My PC:windows
DEVICE_TOKEN_2=changeme_token2:my-phone:My Phone:android
# Optional extra devices
DEVICE_TOKEN_3=
DEVICE_TOKEN_4=

# HMAC secret for hashing window_title (used for dedup, prevents rainbow table attacks)
# Generate with: openssl rand -hex 32
HASH_SECRET=changeme_generate_a_random_secret

# Dashboard management token for /api/config/dashboards
# Generate with: openssl rand -hex 24
ADMIN_TOKEN=changeme_admin_token
# Optional alias (if set, backend prefers ADMIN_PASSWORD over ADMIN_TOKEN)
ADMIN_PASSWORD=

# Optional site customization
DISPLAY_NAME=xuyihong
SITE_TITLE=xuyihong Now
SITE_DESC=What is xuyihong doing right now?
SITE_FAVICON=/favicon.ico
EXTERNAL_DASHBOARDS=[]
